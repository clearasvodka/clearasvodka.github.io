---
import PageLayout from "../layouts/PageLayout.astro";
const pageTitle = "Journal";
---

<PageLayout pageTitle={pageTitle}>
  <p>Lead Paragraph</p>
  <hr />
  <div class="blog-grid-container">
    <div class="blog-grid-item">Post Placeholder</div>
  </div>
</PageLayout>

<style>
  .blog-grid-item {
    height: 320px;
    background: var(--cav-color-surface);
    border-radius: 4px;
    color: var(--cav-color-content-secondary);
  }

  @supports (display: grid-lanes) {
    .blog-grid-container {
      display: grid-lanes;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      flow-tolerance: 20px;
      gap: 16px;
    }
  }
  @supports not (display: grid-lanes) {
    .blog-grid-container {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }
</style>
